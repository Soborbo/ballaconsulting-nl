---
export const prerender = true;

import { Image } from 'astro:assets';
import '../styles/main.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyBar from '../components/StickyBar.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import MainScripts from '../components/MainScripts.astro';
import logoWhite from '../assets/logo-white.svg';
import budapestHero from '../assets/budapest1.webp';
import mariaBalla from '../assets/maria-balla.webp';
import dsc8696 from '../assets/DSC_8696.webp';
import dsc8540 from '../assets/DSC_8540.webp';
import ytThumb from '../assets/yt-thumb.webp';
import cityBudapest from '../assets/city-budapest.webp';

const structuredData = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Balla Consulting",
    "url": "https://ballaconsulting.com",
    "logo": "https://ballaconsulting.com/logo-white.svg",
    "description": "Kijk verder dan Nederland en investeer in Hongarije. Balla Consulting biedt een sleutelklare investerings-infrastructuur, vastgoed sourcing, renovatiebeheer en bedrijfsoprichting.",
    "email": "maria.balla@ballaconsulting.com",
    "telephone": "+31618445121",
    "address": {"@type": "PostalAddress", "addressLocality": "Amstelveen", "addressCountry": "NL"},
    "founder": {"@type": "Person", "name": "Maria Balla", "jobTitle": "Chief Advisor"},
    "areaServed": ["NL", "HU"],
    "sameAs": ["https://x.com/BallaMa49578", "https://www.linkedin.com/company/balla-consulting"]
  }),
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Balla Consulting – Uw Weg naar Groei",
    "description": "Kijk verder dan Nederland en investeer in Hongarije. Sleutelklare investerings-infrastructuur, vastgoed sourcing, renovatiebeheer en bedrijfsoprichting.",
    "url": "https://ballaconsulting.com/nl",
    "inLanguage": "nl",
    "publisher": {"@type": "Organization", "name": "Balla Consulting"}
  })
];
---

<BaseLayout
  title="Balla Consulting – Uw Weg naar Groei"
  description="Kijk verder dan Nederland en investeer in Hongarije. Balla Consulting biedt een sleutelklare investerings-infrastructuur, vastgoed sourcing, renovatiebeheer en bedrijfsoprichting."
  ogTitle="Balla Consulting – Uw Weg naar Groei"
  ogDescription="Kijk verder dan Nederland en investeer in Hongarije. Sleutelklare investerings-infrastructuur, vastgoed sourcing, renovatiebeheer en bedrijfsoprichting."
  ogImage="https://ballaconsulting.com/assets/og-nl.jpg"
  ogUrl="https://ballaconsulting.com/nl"
  ogType="website"
  ogLocale="nl_NL"
  twitterTitle="Balla Consulting – Uw Weg naar Groei"
  twitterDescription="Kijk verder dan Nederland en investeer in Hongarije."
  twitterImage="https://ballaconsulting.com/assets/og-nl.jpg"
  lang="nl"
  includeBelleAurore={true}
  structuredData={structuredData}
>

<style is:global>
  .hero-message { max-width: 650px; }
  .hero-message h1 { font-size: 40px; }
</style>


<StickyBar
  privateDealsLabel="Toegang tot Private Deals"
  privateDealsHref="#private-list"
  ctaLabel="Gratis Kennismakingsgesprek Inplannen"
  ctaHref="#schedule"
/>

<!-- ===== HERO ===== -->
<section class="hero" id="home">
    <!-- Top navigation over the hero -->
    <nav class="top-nav">
        <a href="/" class="lang-switch">EN</a>
        <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="navLinks">
            <a href="#about">Over ons</a>
            <a href="#principles">Uitgangspunten</a>
            <a href="#services">Diensten</a>
            <a href="#fees">Tarieven</a>
            <a href="/guide-nl">Gids</a>
            <a href="#private-list">Investeringsmogelijkheden</a>
            <a href="#contact">Contact</a>
        </div>
    </nav>

    <div class="hero-video-side">
        <Image src={budapestHero} alt="Budapest Parliament Building and Chain Bridge at dusk" widths={[480, 768, 1024, 1280]} sizes="(max-width: 768px) 100vw, 50vw" fetchpriority="high" loading="eager" />
        <div class="hero-video-overlay"></div>
    </div>
    <div class="hero-message-side">
        <div class="hero-message">
            <Image src={logoWhite} alt="Balla Consulting" class="hero-logo" />
            <p class="hero-tagline">Investeer in <strong>Hongarije</strong> met vertrouwen</p>
            <h1>Maximaliseer uw rendement<br><span>Beperk uw risico</span></h1>
            <div class="hero-divider"></div>
            <p style="font-size:16px;">Ondergewaardeerd vastgoed &middot; Strategisch investeren in Hongarije</p>
            <a href="#schedule" class="hero-cta-btn" style="margin-top:35px;">Plan een kosteloos kennismakingsgesprek</a>
        </div>
        <a href="#challenge" class="hero-scroll-arrow" aria-label="Scroll down">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
    </div>
</section>

<!-- ===== INVESTOR CHALLENGE & SOLUTION ===== -->
<section class="challenge-section" id="challenge">
    <div class="container">
        <h2 class="section-title">Waarom buiten Nederland kijken en investeren in Hongarije?</h2>
        <p class="section-subtitle">Laat uw kapitaal direct voor u werken</p>
        <div class="challenge-grid">
            <div class="challenge-box">
                <h3><span class="icon-dot"></span> De uitdaging voor investeerders</h3>
                <p>De Nederlandse markt is voor beleggers momenteel uitdagend. Aanvangsrendementen staan onder druk en strenge huurbescherming kan ertoe leiden dat vastgoed voor langere tijd minder liquide blijft.</p>
                <p>Hongarije biedt daarentegen solide groeiperspectieven en een meer liquide markt. Tegelijkertijd is de toetredingsdrempel hoger. Complexe regelgeving, een competitieve vastgoedmarkt en de taalbarrière maken het voor veel investeerders lastig om de eerste stap te zetten.</p>
            </div>
            <div class="challenge-box">
                <h3><span class="icon-dot" style="background:var(--gold)"></span> Onze oplossing</h3>
                <p>Wij bieden een gestructureerde en geïntegreerde aanpak voor uw investering.</p>
                <p>Van het selecteren van ondergewaardeerde woningen of bedrijfsmatig vastgoed, het voeren van onderhandelingen tot het begeleiden van renovaties en het opzetten van een passende vennootschapsstructuur — Balla Consulting regisseert het volledige traject.</p>
                <p class="highlight">U behoudt de eigendom. Wij bewaken de uitvoering.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== ABOUT ===== -->
<section class="about-section" id="about">
    <div class="container">
        <h2 class="section-title">Over ons</h2>
        <p class="section-subtitle">Uw partner in Hongaarse vastgoed- en bedrijfsinvesteringen</p>
        <div class="about-layout">
            <div class="about-photo">
                <Image src={mariaBalla} alt="Maria Balla – Balla Consulting" widths={[400, 600, 800]} sizes="(max-width: 768px) 100vw, 400px" loading="lazy" />
                <p class="photo-label">Maria Balla</p>
                <p class="photo-role">Chief Advisor</p>
            </div>
            <div class="about-text">
                <p>Ik ben Maria Balla, geboren in Hongarije en sinds 2018 woonachtig in Amsterdam. Met Balla Consulting begeleid ik ondernemers en particulieren die actief willen worden in Hongarije.</p>
                <p>In de afgelopen jaren heb ik voor cliënten vastgoed in Hongarije aangekocht en renovaties begeleid, van eerste bezichtiging tot verhuur. Ik ken de markt van binnenuit en weet waar de aandachtspunten liggen — juridisch, praktisch en financieel. Het gaat daarbij niet alleen om het vinden van een goed object, maar om het zorgvuldig uitvoeren van het hele project.</p>
                <p>Mijn loopbaan heeft mij in vijf landen gebracht — Zwitserland, het Verenigd Koninkrijk, Oostenrijk, Nederland en Hongarije — binnen zowel private banking als internationale bedrijfsvoering. Daardoor begrijp ik hoe het is om in een nieuwe omgeving zaken te doen. U wilt duidelijkheid, betrouwbaarheid en iemand ter plaatse die meedenkt en vooruitkijkt.</p>
                <p>Die rol neem ik graag op mij. Of het nu gaat om het selecteren van passend vastgoed in Hongarije of het oprichten van een fiscaal geoptimaliseerde Kft, ik zorg dat het project overzichtelijk verloopt en dat u weet waar u aan toe bent.</p>
                <p>Voor mij draait het om betrokkenheid en zorgvuldigheid. Geen snelle transacties, maar duurzame keuzes.</p>
                <p>Wilt u bespreken wat in uw situatie mogelijk is? Dan maken wij graag kennis.</p>
                <p class="about-signature">Maria Balla</p>
            </div>
        </div>
        <div class="team-grid">
            <div class="team-member">
                <div class="member-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="20"/><line x1="4" y1="5" x2="20" y2="5"/><path d="M4 5L2 13c0 1.7 1.3 3 3 3s3-1.3 3-3L6 5"/><path d="M18 5l2 8c0 1.7-1.3 3-3 3s-3-1.3-3-3l2-8"/><line x1="8" y1="20" x2="16" y2="20"/><line x1="10" y1="22" x2="14" y2="22"/></svg></div>
                <h4>Dr. Judit Márton</h4>
                <p>Juridisch adviseur en advocaat</p>
                <p class="member-bio">Met meer dan 20 jaar ervaring is Dr. Judit Márton gespecialiseerd in vastgoedrecht en bedrijfsoprichting. Zij ondersteunt internationale investeerders bij het uitbreiden van hun vastgoedbezit en hun zakelijke aanwezigheid in Hongarije.</p>
            </div>
            <div class="team-member">
                <div class="member-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
                <h4>Csaba Gidró</h4>
                <p>Renovatieadviseur</p>
                <p class="member-bio">Csaba Gidró beschikt over meer dan 15 jaar ervaring in vastgoedrenovatie en begeleidt projecten van planning tot oplevering. Hij zorgt voor een soepel verloop en hoogwaardige resultaten voor onze klanten.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== SERVICES ===== -->
<section class="services-section" id="services">
    <div class="container">
        <h2 class="section-title">Diensten</h2>
        <p class="section-subtitle">Vastgoedbegeleiding en ondernemingsstructuur</p>
        <div class="services-columns">
            <div class="service-column">
                <h3>Vastgoedbegeleiding in Hongarije</h3>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
                    <div>
                        <h4>Selectie van geschikte objecten</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                    <div>
                        <h4>Juridische begeleiding bij aankoop</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
                    <div>
                        <h4>Coördinatie van renovaties</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
                    <div>
                        <h4>Voorbereiding van verhuur</h4>
                    </div>
                </div>
            </div>
            <div class="service-column">
                <h3>Ondernemingsstructuur in Hongarije</h3>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22V10h6v12"/><path d="M9 6h.01M15 6h.01"/></svg></div>
                    <div>
                        <h4>Oprichting van een Kft (B.V.)</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                    <div>
                        <h4>Registratie bij bevoegde instanties</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 9.5H9.5a3.5 3.5 0 1 0 0 7H17"/><line x1="6" y1="9.5" x2="20" y2="9.5"/><line x1="6" y1="16.5" x2="20" y2="16.5"/></svg></div>
                    <div>
                        <h4>Praktische begeleiding bij bankrelatie en vestigingsadres</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CHALLENGES WE SOLVE ===== -->
<section class="solve-section">
    <div class="container">
        <h2 class="section-title">Uitdagingen die wij oplossen</h2>
        <p class="section-subtitle">Klik om onze oplossingen te ontdekken</p>
        <div class="solve-grid">
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div>
                <h3>Toegang tot verborgen rendement</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>Openbare aanbiedingen zijn vaak scherp geprijsd en sterk concurrerend.</p>
                <p class="solution-label">Oplossing</p>
                <p>Wij werken niet uitsluitend via openbare vastgoedportalen, maar benutten ons lokale netwerk om toegang te krijgen tot transacties buiten het brede aanbod. Hierdoor ontstaat toegang tot investeringsmogelijkheden met daadwerkelijk waardepotentieel.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5l9-7 9 7"/><path d="M5 9.5v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8"/><path d="M2 21c2-1 4-1.5 6-1.5s4 1 6 1.5 4 .5 6-.5"/><path d="M9 14h6v4.5H9z"/></svg></div>
                <h3>Toegang tot een flexibele huurmarkt</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>De Nederlandse vastgoedmarkt wordt gekenmerkt door strenge huurbescherming, langdurige contractvormen en gereguleerde huurprijzen, wat de flexibiliteit en het rendement voor beleggers kan beperken.</p>
                <p class="solution-label">Oplossing</p>
                <p>Wij begeleiden u naar een markt waarin eigendom en contractuele afspraken beter in balans zijn. In Hongarije worden huurprijzen bepaald door de markt en zijn tijdelijke contracten juridisch afdwingbaar, waardoor uw vastgoed liquide en rendabel blijft.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
                <h3>Ruimte voor groei</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>In volwassen markten zoals Nederland zijn vastgoedprijzen vaak al op een hoog niveau, waardoor verdere waardegroei beperkt kan zijn.</p>
                <p class="solution-label">Oplossing</p>
                <p>Wij richten ons op markten zoals Hongarije, waar instapprijzen nog toegankelijk zijn en ruimte bestaat voor structurele waardegroei.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
                <h3>Juridische zekerheid</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>Een buitenlandse juridische omgeving kan complex en onoverzichtelijk zijn.</p>
                <p class="solution-label">Oplossing</p>
                <p>Balla Consulting werkt volgens een zorgvuldige en gestructureerde aanpak. In samenwerking met gespecialiseerde vastgoedadvocaten worden alle documenten gecontroleerd, zodat uw eigendom juridisch correct en veilig wordt overgedragen.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M14.7 10.3a1 1 0 0 0 0 1.4l.6.6a1 1 0 0 0 1.4 0l1.3-1.3a3 3 0 0 1-4-4l1.3 1.3z"/></svg></div>
                <h3>Renovatie onder regie</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>Het op afstand aansturen van een renovatie brengt risico's en vertraging met zich mee.</p>
                <p class="solution-label">Oplossing</p>
                <p>Wij treden op als lokale projectmanager. Wij selecteren en begeleiden aannemers, bewaken planning en budget en zorgen voor een gecontroleerde uitvoering. Zo wordt vastgoed met potentie ontwikkeld tot een kwalitatief en rendabel object.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg></div>
                <h3>Fiscaal voordeel</h3>
                <p class="challenge-label">De uitdaging</p>
                <p>In delen van West-Europa kunnen hogere belastingtarieven de winstmarges van internationaal actieve bedrijven beperken.</p>
                <p class="solution-label">Oplossing</p>
                <p>Wij helpen u inzicht te krijgen in de mogelijke voordelen van het Hongaarse vennootschapsbelastingtarief van 9%, waar van toepassing, en wij verzorgen de oprichting en naleving—zodat u zich kunt richten op groei.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== FEE STRUCTURE ===== -->
<section class="fees-section" id="fees">
    <div class="container">
        <h2 class="section-title">Transparantie staat centraal</h2>
        <p class="section-subtitle">Duidelijke, vooraf vastgestelde vergoedingen</p>
        <div class="fee-cards">
            <!-- Aankoopbegeleiding -->
            <div class="fee-card">
                <div class="fee-card-header">
                    <h3>Aankoopbegeleiding</h3>
                    <p>Voor investeerders die een veilige aankoop wensen en het beheer zelf uitvoeren.</p>
                </div>
                <div class="fee-card-body">
                    <div class="fee-item">
                        <p class="fee-label">Startvergoeding</p>
                        <p class="fee-value">&euro;950</p>
                        <p class="fee-note">Voor aanvang van het traject vragen wij een startvergoeding. Deze dekt het initiële onderzoek, selectie en eerste beoordelingen ter plaatse.</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Succesvergoeding</p>
                        <p class="fee-value">2,0% van de aankoopprijs</p>
                        <p class="fee-note">Bij succesvolle aankoop rekenen wij een succesvergoeding van 2,0%. De startvergoeding van &euro;950 wordt hiermee verrekend.</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Minimum</p>
                        <p class="fee-value">&euro;3.000</p>
                        <p class="fee-note">(Exclusief btw en wettelijke kosten zoals notaris en overdrachtsbelasting)</p>
                    </div>
                    <h4 style="margin-top: 16px;">Inclusief:</h4>
                    <ul style="list-style:none; margin-top: 8px;">
