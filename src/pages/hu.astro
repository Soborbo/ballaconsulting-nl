---
export const prerender = true;

import { Image } from 'astro:assets';
import '../styles/hu.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyBar from '../components/StickyBar.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import MainScripts from '../components/MainScripts.astro';
import logoWhite from '../assets/logo-white.svg';
import budapestHero from '../assets/budapest1.webp';
import mariaFascetti from '../assets/maria-fascetti.webp';
import dsc8696 from '../assets/DSC_8696.webp';

const structuredData = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Balla Consulting",
    "url": "https://ballaconsulting.com",
    "logo": "https://ballaconsulting.com/logo-white.svg",
    "description": "Holland cégalapítás megbízhatóan. Segítünk a nyugat-európai piacra lépésben.",
    "email": "maria.balla@ballaconsulting.com",
    "telephone": "+31618445121",
    "address": {"@type": "PostalAddress", "addressLocality": "Amstelveen", "addressCountry": "NL"},
    "founder": {"@type": "Person", "name": "Maria Balla Fascetti", "jobTitle": "Chief Advisor"},
    "areaServed": ["NL", "HU"],
    "sameAs": ["https://x.com/BallaMa49578", "https://www.linkedin.com/company/balla-consulting"]
  }),
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Balla Consulting – Útja a Növekedéshez",
    "description": "Holland cégalapítás megbízhatóan. Segítünk a nyugat-európai piacra lépésben.",
    "url": "https://ballaconsulting.com/hu",
    "inLanguage": "hu",
    "publisher": {"@type": "Organization", "name": "Balla Consulting"}
  })
];
---

<BaseLayout
  title="Balla Consulting – Útja a Növekedéshez"
  description="Holland cégalapítás megbízhatóan. Balla Consulting segít a nyugat-európai piacra lépésben, cégjogi tanácsadással és teljes körű ügyintézéssel."
  ogTitle="Balla Consulting – Útja a Növekedéshez"
  ogDescription="Holland cégalapítás megbízhatóan. Segítünk a nyugat-európai piacra lépésben."
  ogImage="https://ballaconsulting.com/assets/og-hu.jpg"
  ogUrl="https://ballaconsulting.com/hu"
  ogType="website"
  ogLocale="hu_HU"
  twitterTitle="Balla Consulting – Útja a Növekedéshez"
  twitterDescription="Holland cégalapítás megbízhatóan."
  twitterImage="https://ballaconsulting.com/assets/og-hu.jpg"
  lang="hu"
  canonicalUrl="https://ballaconsulting.com/hu"
  alternates={[
    { hreflang: 'en', href: 'https://ballaconsulting.com/' },
    { hreflang: 'nl', href: 'https://ballaconsulting.com/nl' },
    { hreflang: 'hu', href: 'https://ballaconsulting.com/hu' },
    { hreflang: 'x-default', href: 'https://ballaconsulting.com/' }
  ]}
  includeBelleAurore={false}
  structuredData={structuredData}
>


<StickyBar
  showPrivateDeals={false}
  ctaLabel="Kérjen INGYENES Konzultációt"
  ctaHref="#schedule"
/>

<!-- ===== HERO ===== -->
<section class="hero" id="home">
    <!-- Top navigation over the hero -->
    <nav class="top-nav">
        <a href="/" class="lang-switch">EN</a>
        <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="navLinks">
            <a href="#about">Rólunk</a>
            <a href="#services">Szolgáltatások</a>
            <a href="#fees">Árak</a>
            <a href="#contact">Kapcsolat</a>
            <a href="#blog">Blog</a>
        </div>
    </nav>

    <div class="hero-video-side">
        <Image src={budapestHero} alt="Budapest Parlament és Lánchíd alkonyatkor" widths={[480, 768, 1024, 1280]} sizes="(max-width: 768px) 100vw, 50vw" fetchpriority="high" loading="eager" />
        <div class="hero-video-overlay"></div>
    </div>
    <div class="hero-message-side">
        <div class="hero-message">
            <Image src={logoWhite} alt="Balla Consulting" class="hero-logo" />
            <p class="hero-tagline">Lépjen a Nyugat-Európai Piacra</p>
            <h1>Holland Cégalapítás.<br><span>Megbízhatóan.</span></h1>
            <div class="hero-divider"></div>
            <p>Holland B.V. alapítás &middot; Adóhatékonyság &middot; Szakmai támogatás</p>
            <a href="#schedule" class="hero-cta-btn" style="margin-top:35px;">Kérjen Konzultációt</a>
        </div>
        <a href="#challenge" class="hero-scroll-arrow" aria-label="Görgessen le">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
    </div>
</section>

<!-- ===== MIÉRT HOLLANDIA ===== -->
<section class="challenge-section" id="challenge">
    <div class="container">
        <h2 class="section-title">Miért Hollandia?</h2>
        <p class="section-subtitle">Stabil háttér a nemzetközi terjeszkedéshez</p>
        <div class="challenge-grid">
            <div class="challenge-box">
                <h3><span class="icon-dot"></span> A Kihívás</h3>
                <p>A magyar vállalkozások Nyugat-Európában bizalmi fenntartásokkal és szigorúbb fizetési feltételekkel szembesülnek. A holland piac fejlett, de a belépés összetett: jogi követelmények, adminisztráció és a nyelvi akadály megnehezítik az önálló indulást.</p>
            </div>
            <div class="challenge-box">
                <h3><span class="icon-dot"></span> A Megoldás</h3>
                <p>Teljes körű infrastruktúrát biztosítunk a holland piacra lépéshez. A cégalapítástól a hatósági ügyintézésen át a kapcsolatrendszer kiépítéséig a Balla Consulting az egész folyamatot kezeli.</p>
                <p class="highlight">Mi végezzük a nehéz munkát, Ön pedig a növekedésre koncentrálhat.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== ALAPELVEK ===== -->
<section class="principles-section" id="principles">
    <div class="container">
        <h2 class="section-title">Alapelveink</h2>
        <p class="section-subtitle">Értékteremtő Megközelítés — Hogyan Dolgozunk</p>
        <div class="principles-grid">
            <div class="principle-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/></svg></div>
                <h3>Nemzetközi Hitelesség</h3>
                <h4>Nyugat-Európai Jelenlét</h4>
                <ul>
                    <li>A magyar vállalkozások Nyugat-Európában bizalmi fenntartásokkal és szigorúbb fizetési feltételekkel szembesülnek.</li>
                    <li>Létrehozzuk az Ön holland jelenlétét, lehetővé téve az Euróban történő egyszerű számlázást és az üzletkötéshez szükséges hitelességet.</li>
                </ul>
            </div>
            <div class="principle-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M4 7h16M6 7l2 10h8l2-10M9 12h6"/></svg></div>
                <h3>Adóhatékonyság</h3>
                <h4>Határokon Átnyúló Struktúrák</h4>
                <ul>
                    <li>A határokon átnyúló nyereség áramoltatás adózási többletterhet és adminisztratív nehézségeket okozhat.</li>
                    <li>Jól kialakított vállalati struktúrával az osztalékok és tőkenyereségek szabályosan áramolhatnak a két ország között.</li>
                </ul>
            </div>
            <div class="principle-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></div>
                <h3>Finanszírozási Tanácsadás</h3>
                <h4>Támogatások és Pályázatok</h4>
                <ul>
                    <li>A holland finanszírozási környezet összetett, és a külföldi vállalkozók sokszor nem jutnak hozzá a támogatásokhoz.</li>
                    <li>Feltérképezzük a kormányzati innovációs támogatásokat és finanszírozási csatornákat, amelyekre vállalkozása jogosult lehet.</li>
                </ul>
            </div>
            <div class="principle-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
                <h3>Holland Kapcsolatok</h3>
                <h4>Üzleti Hálózat</h4>
                <ul>
                    <li>A szakmai hálózat felépítése akár évekbe is telhet, ami lassítja a piaci növekedését.</li>
                    <li>A megfelelő üzleti közösségekhez irányítjuk Önt, így vállalkozása azonnal helyi jelenlétet biztosít.</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ===== RÓLUNK ===== -->
<section class="about-section" id="about">
    <div class="container">
        <h2 class="section-title">Rólunk</h2>
        <p class="section-subtitle">Helyi jelenlét. Nemzetközi tapasztalat.</p>
        <div class="about-layout">
            <div class="about-photo">
                <Image src={mariaFascetti} alt="Maria Balla Fascetti – A Balla Consulting alapítója" widths={[400, 600, 800]} sizes="(max-width: 768px) 100vw, 400px" loading="lazy" />
                <p class="photo-label">Maria Balla Fascetti</p>
                <p class="photo-role">Alapító</p>
            </div>
            <div class="about-text">
                <p>A Balla Consulting alapítójaként magyar cégeknek és magánszemélyeknek segítek abban, hogy kiszámíthatóan és biztonságosan indíthassák el holland vállalkozásukat és léphessenek a nyugat-európai piacra.</p>
                <p>2018 óta élek és dolgozom Amszterdamban. Ez idő alatt nemcsak megismertem, hanem aktív részese is váltam a holland üzleti életnek. Naprakész ismereteim lehetővé teszik, hogy ügyfeleim tisztában legyenek a helyi szabályozásokkal es elkerüljék a buktatókat, amelyekbe egyedül belefuthatnának.</p>
                <p>Szakmai éveim alatt világossá vált számomra, hogy ügyfeleim nem csak általános információkat keresnek, hanem egy partnert is, aki végigkíséri őket a cégalapítás folyamatán.</p>
                <p><strong>Mit jelent a gyakorlatban ez a partnerség?</strong></p>
                <p>Legyen szó holland cégalapításról vagy piaci terjeszkedésről, a tanácsadáson túl csapatommal operatív segítséget is nyújtok. Koordinálom a teljes folyamatot, felügyelem a jogi ügymenetet, és személyesen járok el a hivatalos szerveknél az Ön érdekében.</p>
                <p>Szolgáltatásaink túlmutatnak a papírmunkán: segítünk elindítani kapcsolatrendszerének kiépítését, feltérképezzük a holland állami támogatásokat, és igény esetén a teljes hollandiai letelepedést is megszervezzük.</p>
                <p>Ha készen áll, hogy egy stabil hátterű nyugat-európai piac felé nyisson, beszéljünk.</p>
                <p class="about-signature">Maria Balla Fascetti</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== SZOLGÁLTATÁSOK ===== -->
<section class="services-section" id="services">
    <div class="services-bg">
        <Image src={dsc8696} alt="" widths={[400, 600, 800]} sizes="(max-width: 768px) 100vw, 600px" loading="lazy" />
    </div>
    <div class="container">
        <h2 class="section-title">Belépés a Holland Piacra</h2>
        <p class="section-subtitle">Ideális megoldás magyar cégeknek</p>
        <div class="services-columns">
            <div class="service-column">
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22V10h6v12"/><path d="M9 6h.01M15 6h.01"/></svg></div>
                    <div>
                        <h4>Holland cégalapítás közjegyzői közreműködéssel – minden jogi lépés biztonságosan lebonyolítva</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                    <div>
                        <h4>Bejegyzés a Holland Kereskedelmi Kamarába (KVK)</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 9.5H9.5a3.5 3.5 0 1 0 0 7H17"/><line x1="6" y1="9.5" x2="20" y2="9.5"/><line x1="6" y1="16.5" x2="20" y2="16.5"/></svg></div>
                    <div>
                        <h4>Adószám (RSIN) és ÁFA-regisztráció</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
                    <div>
                        <h4>UBO-regisztráció</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg></div>
                    <div>
                        <h4>Könyvelés és pénzügyi támogatás megbízható partnerhálózatunk segítségével</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
                    <div>
                        <h4>Állami támogatások feltérképezése</h4>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/></svg></div>
                    <div>
                        <h4>Üzleti kapcsolatrendszer kiépítésének gyors és egyszerű elindítása</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== ÁRAK ===== -->
<section class="fees-section" id="fees">
    <div class="container">
        <h2 class="section-title">Átlátható Árazás</h2>
        <p class="section-subtitle">Tiszta, előre meghatározott díjak, rejtett költségek nélkül</p>
        <div class="fee-cards">
            <div class="fee-card">
                <div class="fee-card-header">
                    <h3>Holland Piaci Belépés (B.V.)</h3>
                    <p>Magyar vállalkozóknak, akik holland jogi személyt szeretnének létrehozni.</p>
                </div>
                <div class="fee-card-body">
                    <div class="fee-item">
                        <p class="fee-label">Fix Ár</p>
                        <p class="fee-value">&euro;1,850</p>
                        <p class="fee-note">A törvényben előírt közjegyzői, vállalat regisztrációs díjakat és az ÁFA-t nem tartalmazza</p>
                    </div>
                    <h4 style="margin-top: 16px;">Tartalmazza:</h4>
                    <ul style="list-style:none; margin-top: 8px;">
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Holland cégalapítás közjegyzői közreműködéssel</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Bejegyzés a Holland Kereskedelmi Kamarába (KVK)</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Adószám (RSIN) és ÁFA-regisztráció</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> UBO-regisztráció</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Könyvelés és pénzügyi támogatás megbízható partnerhálózatunk segítségével</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Állami támogatások feltérképezése</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Üzleti kapcsolatrendszer kiépítésének gyors és egyszerű elindítása</li>
                    </ul>
                </div>
                <a href="#contact" class="fee-cta">Ajánlatkérés</a>
            </div>
        </div>
    </div>
</section>

<!-- ===== HOOK A ===== -->
<section class="hook-map-section" id="hook-bv">
    <div class="container" style="text-align:center;">
        <h2 class="section-title">A Holland B.V. a Megfelelő Választás az Ön Számára?</h2>
        <a href="#" class="hero-cta-btn">B.V. vs. Kft Összehasonlító Letöltése</a>
    </div>
</section>

<!-- ===== BLOG ===== -->
<section class="blog-section" id="blog">
    <div class="container">
        <h2 class="section-title">Blog</h2>
        <p class="section-subtitle">Szakmai betekintés</p>
        <div class="blog-card">
            <h3>A Holland B.V.</h3>
            <p class="blog-sub">Az egyik legrugalmasabb vállalkozási forma Európában</p>
            <p>A holland B.V. az egyik legrugalmasabb, startup-barát vállalkozási forma Európában. A minimális alaptőke csak 0,01 euró ellentétbe a magyar 3 000 000 Ft-os induló összeggel. Az alapítás körülbelül 5 munkanapot vesz igénybe és közjegyző közreműködésével történik. Hollandia kiváló nemzetközi hírnévvel rendelkezik, fejlett angol nyelvű jogi és könyvelési infrastruktúrára épül, és számos adóegyezményi megállapodást kötött más országokkal, köztük Magyarországgal is.</p>
            <a href="#" class="read-more">Teljes Cikk Olvasása &rarr;</a>
        </div>
    </div>
</section>

<!-- ===== GYIK ===== -->
<section class="faq-section" id="faq">
    <div class="container">
        <h2 class="section-title">Gyakran Ismételt Kérdések</h2>
        <p class="section-subtitle">Minden, amit a holland cégalapításról tudni érdemes</p>

        <div class="faq-category">
            <h3>Cégalapítás és Struktúra</h3>

            <div class="faq-item">
                <div class="faq-question">Miért érdemes egy magyar vállalatnak holland Kft.-t (B.V.-t) alapítania? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">A holland B.V. erős nemzetközi hitelességet, stabil hírnevet, kiszámítható jogi környezetet és közvetlen hozzáférést nyújt a fejlett nyugat-európai pénzügyi és üzleti piacokhoz.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Segítenek egy B.V., vagy bármilyen más holland cégforma alapításában? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Igen. Ha magyar vállalkozóként a nyugat-európai piacra kíván lépni, végigkísérjük a holland cégalapítás teljes folyamatán és gondoskodunk arról, hogy vállalkozása minden jogi és adminisztratív követelménynek maradéktalanul megfeleljen.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">A B.V. megegyezik a magyar Kft.-vel? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Nagyon hasonlóak. Mindkettő korlátolt felelősségű társaság. A holland B.V. azonban rugalmassága és Hollandia kiterjedt adóegyezmény-hálózata miatt világszerte elismert prémium vállalati forma.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Mennyi a minimális alaptőke a BV-ben? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">2012 óta a minimális tőkekövetelmény mindössze 0,01 euró (egy cent) a magyar 3 millió forint követelménnyel szemben.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Lehet magyar állampolgárnak vagy magyar cégnek 100%-os tulajdonrésze egy holland B.V.-ben? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Igen. Nincs korlátozás a külföldi tulajdonra vonatkozóan. Magyar magánszemély vagy magyar cég is lehet 100%-os tulajdonos.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Hollandiába kell utaznom a papírok aláírásához? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Nem feltétlenül. A cégbejegyzést közjegyzői meghatalmazás útján is elintézhetjük. (bizonyos esetekben ehhez meg hivatalos hitelesítés is szükséges) A bankszámla megnyitásához azonban a személyes megjelenés elengedhetetlen.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Szüksége van a B.V.-nek fizikai irodára Hollandiában? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Igen, a vállalatnak regisztrált címre van szüksége.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Mennyi ideig tart a regisztrációs folyamat? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Ha minden szükséges dokumentum (útlevélmásolat, lakcímigazolás, stb.) rendelkezésre áll, a holland közjegyző általában 5–10 munkanap alatt elkészíti az alapító okiratot. Ezután a cég bejegyzése a Kereskedelmi Kamarában 1–2 munkanap alatt megtörténik, így a teljes folyamat általában 2 hét alatt lezárul.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Hogyan alakul a társasági adókulcs? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Hollandia társasági adókulcsa: 19% 200 000 € nyereségig, 25,8% felett. Bár ez magasabb, mint Magyarország 9%-a, a holland leányvállalatoktól kapott osztalékok és tőkenyereségek gyakran 100%-ban adómentesek.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Hogyan nyitható holland üzleti bankszámla? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Hollandiában a banki előírások szigorúak, különösen külföldi tulajdonú cégek esetén. Bár senki sem tudja garantálni a számlanyitást, mi bemutatjuk Önt olyan bankoknak, amelyek nyitottak nemzetközi struktúrákra.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Mi az „UBO" nyilvántartás? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Minden holland B.V. köteles az uniós átláthatósági és átvilágítási szabályoknak megfelelően bejelenteni tulajdonosai adatát. Gondoskodunk a regisztráció szabályos lebonyolításáról, hogy a bankszámlanyitás és a működés zökkenőmentes legyen.</div></div>
            </div>
        </div>

        <div class="faq-category">
            <h3>Adózás</h3>

            <div class="faq-item">
                <div class="faq-question">Hogyan kezeljük a holland B.V. könyvelését? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Bár mi magunk nem vagyunk könyvelők, megbízható holland adótanácsadó partnerekkel dolgozunk együtt. Ezzel biztosítjuk, hogy cége már az első naptól megfeleljen az adózási előírásoknak.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Hogyan kerülhető el a kettős adóztatás Hollandia és Magyarország között? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Hollandia és Magyarország között érvényben van egy adóegyezmény, amely megakadályozza, hogy ugyanazon jövedelem után kétszer fizessen adót. Szolgáltatásunk segítségével az osztalékokat, kamatokat és egyéb jövedelmeket úgy strukturáljuk, hogy azok adóhatékonyan, jogszerűen és zökkenőmentesen áramolhassanak.</div></div>
            </div>
        </div>

        <div class="faq-category">
            <h3>Együttműködés a Balla Consultinggal</h3>

            <div class="faq-item">
                <div class="faq-question">Mekkora a Balla Consulting csapata? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">A Balla Consulting egy butik jellegű tanácsadó cég, ahol ügyfeleink közvetlenül az alapítóval dolgoznak együtt, aki kiterjedt magyar és holland szakmai kapcsolatokkal rendelkezik. A kommunikáció személyes és a felelősségvállalás egyértelmű.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Milyen árazással dolgoznak? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Vállalati szolgáltatásainkat fix díjas csomagokban kínáljuk, amit megtalál az 'árak' menüpontban. A díjazást és a szolgáltatás pontos tartalmát minden esetben írásban, a munka megkezdése előtt rögzítjük.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Ha Hollandiában szeretnék letelepedni, segítenek-e a költözésben? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Bár fő tevékenységünk a cégalapítás, tapasztalatunk kiterjed a letelepedés gyakorlati lépéseire is és külön igény esetén, akár ebben is támogatást nyújthatunk.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Milyen további előnyökkel jár a Balla Consulting szolgáltatásainak igénybevétele? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Pénzügyi lehetőségek feltérképezése: Hollandia kiemelkedő finanszírozási lehetőségeket kínál, de kulcsfontosságú, hogy tudjuk, hol és hogyan kell keresni. Segítünk eligazodni a rendszerben, amelyeket a legtöbb külföldi vállalat kihagy. Helyi kapcsolatrendszer és bizalom: A holland üzleti élet a bizalmon alapul. Összekötjük Önt megbízható adótanácsadókkal, jogi szakemberekkel és partnerekkel, akikkel mi magunk is együtt dolgozunk. Emellett gyakorlati tippeket adunk a helyi üzleti kapcsolatrendszer kiépítéséhez, amely vállalata számára hitelességet, működési lendületet és további növekedési lehetőségeket biztosít.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Miért érdemes a Balla Consultingot választani? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Elsősorban azért, mert magyarul beszélünk, és jól ismerjük a magyar üzleti gondolkodásmódot így a holland jogi környezetben is pontos és gyakorlati tanácsokat adunk. Helyi képviselőként szakmai útmutatással segítünk elkerülni a szabályozási hibákat, igy vállalkozása biztonságosan és zökkenőmentesen működhet.</div></div>
            </div>
            <div class="faq-item">
                <div class="faq-question">Hogyan kezdhetjük el a közös munkát? <span class="faq-toggle">+</span></div>
                <div class="faq-answer"><div class="faq-answer-inner">Első lépésként egy konzultáció keretében átbeszéljük céljait és lehetőségeit, majd ezek alapján személyre szabott stratégiát dolgozunk ki. Az alábbi gombra kattintva közvetlenül is kérhet konzultációt.</div></div>
            </div>
        </div>
    </div>
</section>

