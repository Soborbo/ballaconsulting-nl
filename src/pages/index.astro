            <!-- Placeholder for balance -->
            <div class="fee-card fee-card-full" style="border: 2px dashed var(--gold); background: linear-gradient(135deg, rgba(197,160,89,0.04), rgba(10,25,47,0.06)); box-shadow: 0 4px 20px rgba(197,160,89,0.1);">
                <div class="fee-card-header" style="background: transparent; border-bottom: 1px solid rgba(197,160,89,0.2);">
                    <h3 style="color: var(--navy); font-size: 26px;">Custom Package</h3>
                    <p style="color: var(--text); font-size: 16px;">Need something specific? Let's discuss your requirements.</p>
                </div>
                <div class="fee-card-body" style="display:flex; align-items:center; justify-content:center; min-height: 150px;">
                    <p style="color: var(--text); text-align:center; font-size: 17px; line-height:1.8;">We offer tailored solutions for complex cross-border investments and multi-property portfolios.<br><span style="color:var(--gold); font-weight:700; font-size:14px; letter-spacing:1px; text-transform:uppercase; margin-top:10px; display:inline-block;">Tell us what you need — we'll build it.</span></p>
                </div>
                <a href="#contact" class="fee-cta" style="background: var(--gold); color: var(--navy); font-size: 14px; padding: 14px 36px;">Contact Us</a>
            </div>
        </div>
