---
export const prerender = true;

import '../styles/main.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyBar from '../components/StickyBar.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import MainScripts from '../components/MainScripts.astro';

const structuredData = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Balla Consulting",
    "url": "https://ballaconsulting.com",
    "logo": "https://ballaconsulting.com/logo-white.svg",
    "description": "Look beyond the Netherlands and invest in Hungary. Turn-key investment infrastructure, property sourcing, renovation management and company setup.",
    "email": "maria.balla@ballaconsulting.com",
    "telephone": "+31618445121",
    "address": {"@type": "PostalAddress", "addressLocality": "Amstelveen", "addressCountry": "NL"},
    "founder": {"@type": "Person", "name": "Maria Balla", "jobTitle": "Chief Advisor"},
    "areaServed": ["NL", "HU"],
    "sameAs": ["https://x.com/BallaMa49578", "https://www.linkedin.com/company/balla-consulting"]
  }),
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Balla Consulting – Your Way to Growth",
    "description": "Look beyond the Netherlands and invest in Hungary. Turn-key investment infrastructure, property sourcing, renovation management and company setup.",
    "url": "https://ballaconsulting.com/",
    "inLanguage": "en",
    "publisher": {"@type": "Organization", "name": "Balla Consulting"}
  })
];
---

<BaseLayout
  title="Balla Consulting – Your Way to Growth"
  description="Look beyond the Netherlands and invest in Hungary. Balla Consulting provides turn-key investment infrastructure, property sourcing, renovation management and company setup."
  ogTitle="Balla Consulting – Your Way to Growth"
  ogDescription="Look beyond the Netherlands and invest in Hungary. Turn-key investment infrastructure, property sourcing, renovation management and company setup."
  ogImage="https://ballaconsulting.com/assets/og-index.jpg"
  ogUrl="https://ballaconsulting.com/"
  ogType="website"
  ogLocale="en_US"
  twitterTitle="Balla Consulting – Your Way to Growth"
  twitterDescription="Look beyond the Netherlands and invest in Hungary."
  twitterImage="https://ballaconsulting.com/assets/og-index.jpg"
  lang="en"
  includeBelleAurore={true}
  structuredData={structuredData}
>


<StickyBar />

<!-- ===== HERO ===== -->
<section class="hero" id="home">
    <!-- Top navigation over the hero -->
    <nav class="top-nav">
        <a href="/nl" class="lang-switch">NL</a>
        <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="navLinks">
            <a href="#about">About</a>
            <a href="#principles">Principles</a>
            <a href="#services">Services</a>
            <a href="#fees">Fee Structure</a>
            <a href="/guide">Guide</a>
            <a href="#private-list">Access to Private Deals</a>
            <a href="#contact">Contact</a>
        </div>
    </nav>

    <div class="hero-video-side">
        <img src="/budapest1.webp" alt="Budapest Parliament Building and Chain Bridge at dusk" width="643" height="845" fetchpriority="high">
        <div class="hero-video-overlay"></div>
    </div>
    <div class="hero-message-side">
        <div class="hero-message">
            <img src="/logo-white.svg" alt="Balla Consulting" class="hero-logo">
            <p class="hero-tagline">Invest in <strong>Hungary</strong> Seamlessly</p>
            <h1>Maximize Yield<br><span>Minimize Risk</span></h1>
            <div class="hero-divider"></div>
            <p style="font-size:16px;">Undervalued Assets &middot; Strategic Investment in Hungary</p>
            <a href="#schedule" class="hero-cta-btn" style="margin-top:35px;">Schedule a FREE Initial Consultation</a>
        </div>
        <a href="#challenge" class="hero-scroll-arrow" aria-label="Scroll down">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
    </div>
</section>

<!-- ===== INVESTOR CHALLENGE & SOLUTION ===== -->
<section class="challenge-section" id="challenge">
    <div class="container">
        <h2 class="section-title">Why look beyond the Netherlands and invest in Hungary?</h2>
        <p class="section-subtitle">Turn-key infrastructure for your capital</p>
        <div class="challenge-grid">
            <div class="challenge-box">
                <h3><span class="icon-dot"></span> Investor's Challenge</h3>
                <p>The Dutch market is challenging for investors — low yields and <strong>extreme tenant protection</strong> can make your asset illiquid for years. Hungary offers strong growth and liquidity, yet the barrier to entry remains high. Complex legislation, a demanding property market, and the language challenge can prevent investors to start.</p>
            </div>
            <div class="challenge-box">
                <h3><span class="icon-dot"></span> The Solution</h3>
                <p>We provide a turn-key infrastructure for your capital. From sourcing undervalued properties or industrial assets, negotiating the best price to managing renovations and full company setup, Balla Consulting handles the entire process.</p>
                <p class="highlight">We do the hard work, you own the asset.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== ABOUT ===== -->
<section class="about-section" id="about">
    <div class="container">
        <h2 class="section-title">Meet the Team</h2>
        <p class="section-subtitle">Dedicated professionals. Local presence. International reach.</p>
        <div class="about-layout">
            <div class="about-photo">
                <img src="/assets/maria-balla.webp" alt="Maria Balla – Balla Consulting" width="800" height="1067" loading="lazy">
                <p class="photo-label">Maria Balla</p>
                <p class="photo-role">Chief Advisor</p>
            </div>
            <div class="about-text">
                <p>I am Maria Balla, a Hungarian native based in Amsterdam since 2018. I am the founder of Balla Consulting where we advise institutions, individuals and entrepreneurs who want to invest in Hungary to buy real estate, industrial assets or establish a Hungarian Kft (Ltd) or a cross-border structure.</p>
                <p>Working between the Netherlands and Hungary gives me insight into both markets — from the strict rental legislation and tax pressure in the Netherlands to the higher yields, increasing property values and more flexible tenancy laws available in Hungary.</p>
                <p>With my team I have assisted clients with acquiring properties, overseeing renovations and managing rental operations. This hands-on experience allows me to supervise due diligence, pricing negotiation and tenant placement with care.</p>
                <p>Hungary's 9% corporate income tax — the lowest in the European Union — can provide structural advantages when properly aligned with your investment strategy.</p>
                <p>We provide personalized guidance at every step to our clients to navigate the Hungarian market with clarity and confidence.</p>
                <p>You retain ownership.<br>We ensure local oversight, transparency and high-quality delivery.</p>
                <p>If you are considering investing in Hungary, I welcome a confidential conversation.</p>
                <p class="about-signature">Maria Balla</p>
            </div>
        </div>
        <div class="team-grid">
            <div class="team-member">
                <div class="member-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="20"/><line x1="4" y1="5" x2="20" y2="5"/><path d="M4 5L2 13c0 1.7 1.3 3 3 3s3-1.3 3-3L6 5"/><path d="M18 5l2 8c0 1.7-1.3 3-3 3s-3-1.3-3-3l2-8"/><line x1="8" y1="20" x2="16" y2="20"/><line x1="10" y1="22" x2="14" y2="22"/></svg></div>
                <h4>Dr. Judit Márton</h4>
                <p>Legal Advisor and Attorney</p>
                <p class="member-bio">With over 20 years of experience, Dr. Judit Márton specialises in real estate law and company incorporation, supporting international investors in expanding their portfolios and business presence in Hungary.</p>
            </div>
            <div class="team-member">
                <div class="member-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
                <h4>Csaba Gidró</h4>
                <p>Renovation Advisor</p>
                <p class="member-bio">Csaba Gidró brings 15+ years of experience in property renovation, overseeing projects from planning to completion. He ensures smooth delivery and high-quality outcomes for our clients.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== SERVICES ===== -->
<section class="services-section" id="services">
    <div class="container">
        <h2 class="section-title">Comprehensive Support</h2>
        <p class="section-subtitle">For real estate and business expansion</p>
        <div class="services-columns">
            <div class="service-column">
                <h3>Real Estate Support in Hungary</h3>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
                    <div>
                        <h4>Asset Sourcing</h4>
                        <p>Identifying high-potential assets in Hungary</p>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
                    <div>
                        <h4>Purchase Support</h4>
                        <p>Managing the bidding and legal process till ownership</p>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
                    <div>
                        <h4>Renovation Management</h4>
                        <p>Overseeing renovation to maximize ROI</p>
                    </div>
                </div>
            </div>
            <div class="service-column">
                <h3>Business &amp; Tax Netherlands &amp; Hungary</h3>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22V10h6v12"/><path d="M9 6h.01M15 6h.01"/></svg></div>
                    <div>
                        <h4>Company Registration</h4>
                        <p>Seamless business setup in both jurisdictions</p>
                    </div>
                </div>
                <div class="service-item">
                    <div class="svc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 9.5H9.5a3.5 3.5 0 1 0 0 7H17"/><line x1="6" y1="9.5" x2="20" y2="9.5"/><line x1="6" y1="16.5" x2="20" y2="16.5"/></svg></div>
                    <div>
                        <h4>Tax Optimization</h4>
                        <p>Maximizing corporate tax efficiency and benefits</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== CHALLENGES WE SOLVE ===== -->
<section class="solve-section">
    <div class="container">
        <h2 class="section-title">Challenges We Solve</h2>
        <p class="section-subtitle">Click to explore our solutions</p>
        <div class="solve-grid">
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div>
                <h3>Access to Hidden Yields</h3>
                <p class="challenge-label">The Challenge</p>
                <p>Public listings are often overpriced or highly competitive.</p>
                <p class="solution-label">Solution</p>
                <p>We leverage our local network and sourcing capabilities beyond standard property portals, providing access to investment opportunities with genuine value-add potential.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5l9-7 9 7"/><path d="M5 9.5v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8"/><path d="M2 21c2-1 4-1.5 6-1.5s4 1 6 1.5 4 .5 6-.5"/><path d="M9 14h6v4.5H9z"/></svg></div>
                <h3>Reaching Flexible Rental Market</h3>
                <p class="challenge-label">The Challenge</p>
                <p>The Dutch real estate market is characterized by strong tenant protection, long-term contracts, and regulated rental pricing, which can limit flexibility and returns for investors.</p>
                <p class="solution-label">Solution</p>
                <p>We guide you into a market where ownership rights are clearly defined and protected. Hungarian rental prices are set by the market—not a point based system— fixed-term contracts are fully enforceable, ensuring your asset remains liquid and profitable.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
                <h3>Key to Growth</h3>
                <p class="challenge-label">The Challenge</p>
                <p>In highly developed markets like the Netherlands, the real estate market is already priced at premium, thus limiting meaningful capital growth.</p>
                <p class="solution-label">Solution</p>
                <p>We focus on markets such as Hungary, where entry prices remain accessible and capital growth is strong.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
                <h3>Legal Security</h3>
                <p class="challenge-label">The Challenge</p>
                <p>Navigating a foreign legal system can feel risky and unclear.</p>
                <p class="solution-label">Solution</p>
                <p>Balla Consulting protects your interests with a "Compliance First" standard. Verifying each of your documents with a real estate attorney ensures your ownership and the safety of your investment.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M14.7 10.3a1 1 0 0 0 0 1.4l.6.6a1 1 0 0 0 1.4 0l1.3-1.3a3 3 0 0 1-4-4l1.3 1.3z"/></svg></div>
                <h3>End-to-End Renovation</h3>
                <p class="challenge-label">The Challenge</p>
                <p>Managing a renovation from another country introduces additional risks and delays.</p>
                <p class="solution-label">Solution</p>
                <p>We act as your project manager on spot, reviewing contractors, enforcing timelines, controlling budgets. We transform underperforming properties into income-generating assets, guided by strong local market knowledge.</p>
            </div>
            <div class="solve-card">
                <div class="card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg></div>
                <h3>Tax Advantage</h3>
                <p class="challenge-label">The Challenge</p>
                <p>Higher tax rates in parts of Western Europe may impact profit margins for cross-border businesses.</p>
                <p class="solution-label">Solution</p>
                <p>We advise on the potential benefits of Hungary's 9% corporate tax rate, where applicable, and support company setup and compliance—so you can focus on growth.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===== FEE STRUCTURE ===== -->
<section class="fees-section" id="fees">
    <div class="container">
        <h2 class="section-title">Transparency Is Our Policy</h2>
        <p class="section-subtitle">Clear, upfront pricing with no hidden costs</p>
        <div class="fee-cards">
            <!-- Acquisition Suite -->
            <div class="fee-card">
                <div class="fee-card-header">
                    <h3>The Acquisition Suite</h3>
                    <p>For the investor who wants a secure purchase but plans to manage the property independently.</p>
                </div>
                <div class="fee-card-body">
                    <div class="fee-item">
                        <p class="fee-label">Engagement Retainer</p>
                        <p class="fee-value">€950</p>
                        <p class="fee-note">Deducted from final fee. Covers initial research and on-site due diligence.</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Success Fee</p>
                        <p class="fee-value">2.0% of purchase price</p>
                        <p class="fee-note">Upon successful completion of the acquisition.</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Minimum Total Fee</p>
                        <p class="fee-value">€3,000</p>
                        <p class="fee-note">Excludes VAT and statutory notary/state fees.</p>
                    </div>
                    <h4 style="margin-top: 16px;">Includes:</h4>
                    <ul style="list-style:none; margin-top: 8px;">
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Asset Sourcing</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Due Diligence & Legal Coordination</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Price Negotiation & Contract Review</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Key Handover & Meter Check</li>
                    </ul>
                </div>
                <a href="#contact" class="fee-cta">Request Proposal</a>
            </div>

            <!-- Value-Add Suite -->
            <div class="fee-card">
                <div class="fee-card-header">
                    <h3>The Value-Add Suite</h3>
                    <p>For the investor who wants a turn-key asset delivered ready for rental.</p>
                </div>
                <div class="fee-card-body">
                    <div class="fee-item">
                        <p class="fee-label">Acquisition Fee</p>
                        <p class="fee-value">Same as Acquisition Suite</p>
                        <p class="fee-note">€950 retainer + 2.0% success fee (min. €3,000)</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Renovation Oversight Fee</p>
                        <p class="fee-value">15% of renovation budget</p>
                        <p class="fee-note">5% at start · 5% at midterm · 5% at completion</p>
                    </div>
                    <div class="fee-item">
                        <p class="fee-label">Property Management</p>
                        <p class="fee-value">10% gross monthly rent</p>
                        <p class="fee-note">Maintenance, repairs and third-party costs charged separately.</p>
                    </div>
                </div>
                <a href="#contact" class="fee-cta">Request Proposal</a>
            </div>

            <!-- Corporate Package -->
            <div class="fee-card">
                <div class="fee-card-header">
                    <h3>Hungary Market Entry (Kft)</h3>
                    <p>For Dutch entrepreneurs establishing a low-tax entity.</p>
                </div>
                <div class="fee-card-body">
                    <div class="fee-item">
                        <p class="fee-label">Fixed Price</p>
                        <p class="fee-value">€1,850</p>
                        <p class="fee-note">Excludes VAT and statutory notary/state fees.</p>
                    </div>
                    <h4 style="margin-top: 16px;">Includes:</h4>
                    <ul style="list-style:none; margin-top: 8px;">
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Kft (B.V) Registration & Deed of Foundation</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> VAT & Chamber of Commerce Registration</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Bank Account Introduction</li>
                        <li style="padding: 4px 0; padding-left: 16px; position: relative; font-size: 14px;"><svg style="position:absolute;left:0;top:6px;width:12px;height:12px;color:var(--gold);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Registered Address Setup Assistance</li>
                    </ul>
                </div>
                <a href="#contact" class="fee-cta">Request Proposal</a>
