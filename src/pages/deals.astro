---
export const prerender = true;

import '../styles/main.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

const structuredData = [
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Access to Private Deals – Balla Consulting",
    "description": "Join the Balla Consulting Private List for access to exclusive real estate investment deals in Hungary. No spam, just deal flow.",
    "url": "https://ballaconsulting.com/deals",
    "inLanguage": "en",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Balla Consulting",
      "url": "https://ballaconsulting.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Balla Consulting",
      "url": "https://ballaconsulting.com",
      "logo": "https://ballaconsulting.com/logo-white.svg"
    }
  }),
  JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Private Deals",
    "description": "Exclusive access to curated real estate investment opportunities in Hungary, including off-market properties and value-add renovation projects.",
    "provider": {
      "@type": "Organization",
      "name": "Balla Consulting",
      "url": "https://ballaconsulting.com"
    },
    "areaServed": ["NL", "HU"],
    "serviceType": "Real Estate Investment Advisory"
  })
];
---

<BaseLayout
  title="Private Deals – Balla Consulting"
  description="Join the Balla Consulting Private List for access to exclusive real estate investment deals in Hungary. No spam, just deal flow."
  ogTitle="Access to Private Deals – Balla Consulting"
  ogDescription="Join the Balla Consulting Private List for access to exclusive real estate investment deals in Hungary. No spam, just deal flow."
  ogImage="https://ballaconsulting.com/assets/og-index.jpg"
  ogUrl="https://ballaconsulting.com/deals"
  ogType="website"
  ogLocale="en_US"
  twitterTitle="Access to Private Deals – Balla Consulting"
  twitterDescription="Exclusive real estate investment deals in Hungary. No spam, just deal flow."
  twitterImage="https://ballaconsulting.com/assets/og-index.jpg"
  lang="en"
  structuredData={structuredData}
>

<section class="private-list-section deals-page">
    <div class="deals-bg-orb deals-bg-orb--top"></div>
    <div class="deals-bg-orb deals-bg-orb--bottom"></div>

    <header class="deals-topbar">
        <a href="/" class="deals-logo-link" aria-label="Balla Consulting – home">
            <img src="/logo-white.svg" alt="Balla Consulting" class="deals-logo">
        </a>
        <a href="/" class="deals-back-link">
            <span aria-hidden="true">&larr;</span> Back to ballaconsulting.com
        </a>
    </header>

    <div class="deals-shell">
        <div class="deals-card" id="dealsContent">
            <aside class="deals-portrait">
                <div class="deals-portrait-frame">
                    <img src="/assets/maria-balla.webp" alt="Maria Balla – Balla Consulting" class="deals-portrait-img" loading="eager">
                </div>
                <p class="deals-portrait-name">Maria Balla</p>
                <p class="deals-portrait-role">Chief Advisor</p>
                <span class="deals-portrait-divider" aria-hidden="true"></span>
                <p class="deals-portrait-quote">
                    &ldquo;A short list. Real opportunities. Direct from us to you.&rdquo;
                </p>
            </aside>

            <div class="deals-content">
                <h1 class="deals-title">Access to <em>Private</em> Deals</h1>
                <p class="deals-lede">
                    Join the Balla Consulting Private List for curated, off-market
                    investment opportunities in Hungary &mdash; delivered directly,
                    before they reach the public market.
                </p>

                <div class="deals-form">
                    <div id="eo-form-placeholder" data-form="59431dd6-2dc7-11f1-b866-b7a8a8ccd8c4"></div>
                </div>

                <script is:inline>
                (function(){var p=document.getElementById('eo-form-placeholder');if(!p)return;var s=document.createElement('script');s.src='https://eomail5.com/form/59431dd6-2dc7-11f1-b866-b7a8a8ccd8c4.js';s.async=true;s.dataset.form='59431dd6-2dc7-11f1-b866-b7a8a8ccd8c4';p.parentNode.insertBefore(s,p);})();
                document.addEventListener('emailoctopus:form.success', function() {
                    var content = document.getElementById('dealsContent');
                    if (content) content.style.display = 'none';
                    var msg = document.getElementById('dealsSuccess');
                    if (msg) msg.style.display = 'flex';
                });
                </script>
            </div>
        </div>

        <div id="dealsSuccess" class="deals-success" style="display:none;">
            <div class="deals-success-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="4 12 10 18 20 6"/>
                </svg>
            </div>
            <h2>You&rsquo;re on the list.</h2>
            <p>We&rsquo;ll be in touch when the next opportunity is ready.</p>
            <a href="/" class="deals-success-link">Return to ballaconsulting.com &rarr;</a>
        </div>
    </div>
</section>

<Footer />

</BaseLayout>
