---
interface Props {
  homeHref?: string;
  privateDealsLabel?: string;
  privateDealsHref?: string;
  showPrivateDeals?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  homeHref = '#home',
  privateDealsLabel = 'Access to Private Deals',
  privateDealsHref = '#private-list',
  showPrivateDeals = true,
  ctaLabel = 'Schedule a FREE Initial Consultation',
  ctaHref = '#schedule',
} = Astro.props;
---

<div class="sticky-cta" id="stickyCta">
    <div class="sticky-logo" style="display:flex; align-items:center; gap:18px;">
        <a href={homeHref}><img src="/logo-white.svg" alt="Balla Consulting"></a>
        {showPrivateDeals && <a href={privateDealsHref} style="color:var(--gold); text-decoration:none; font-size:11px; font-weight:700; letter-spacing:1px; text-transform:uppercase; border:1px solid var(--gold); padding:5px 14px; border-radius:4px; white-space:nowrap; transition:background 0.3s, color 0.3s;" onmouseover="this.style.background='#C5A059';this.style.color='#0A192F'" onmouseout="this.style.background='transparent';this.style.color='#C5A059'">{privateDealsLabel}</a>}
    </div>
    <div class="sticky-info">
        <a href="mailto:maria.balla@ballaconsulting.com">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>maria.balla@ballaconsulting.com</span>
        </a>
        <a href="tel:+31618445121">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>+31 618 445121</span>
        </a>
        <a href={ctaHref} class="sticky-btn">{ctaLabel}</a>
    </div>
</div>
