---
// Common JavaScript for main pages (index, nl, hu) and guide pages
---

<script is:inline>
    // Hamburger menu
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const navLinks = document.getElementById('navLinks');
    if (hamburgerBtn && navLinks) {
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        hamburgerBtn.setAttribute('aria-controls', 'navLinks');
        const closeMenu = () => {
            hamburgerBtn.classList.remove('active');
            navLinks.classList.remove('open');
            document.body.classList.remove('menu-open');
            hamburgerBtn.setAttribute('aria-expanded', 'false');
        };
        hamburgerBtn.addEventListener('click', () => {
            const open = hamburgerBtn.classList.toggle('active');
            navLinks.classList.toggle('open', open);
            document.body.classList.toggle('menu-open', open);
            hamburgerBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        navLinks.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    }

    // Sticky CTA bar on scroll (throttled)
    const stickyCta = document.getElementById('stickyCta');
    const heroEl = document.getElementById('home') || document.querySelector('.guide-hero');
    if (stickyCta && heroEl) {
        let ticking = false;
        window.addEventListener('scroll', () => {
            if (!ticking) {
                requestAnimationFrame(() => {
                    const heroBottom = heroEl.offsetTop + heroEl.offsetHeight;
                    if (window.scrollY > heroBottom - 100) {
                        stickyCta.classList.add('visible');
                    } else {
                        stickyCta.classList.remove('visible');
                    }
                    ticking = false;
                });
                ticking = true;
            }
        }, { passive: true });
    }

    // FAQ accordion
    const faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(q => {
        if (!q.hasAttribute('role')) q.setAttribute('role', 'button');
        if (!q.hasAttribute('tabindex')) q.setAttribute('tabindex', '0');
        q.setAttribute('aria-expanded', 'false');
        const toggle = () => {
            const item = q.parentElement;
            if (!item) return;
            const answer = item.querySelector('.faq-answer');
            const isActive = item.classList.contains('active');
            document.querySelectorAll('.faq-item').forEach(i => {
                i.classList.remove('active');
                const a = i.querySelector('.faq-answer');
                if (a) a.style.maxHeight = null;
                const trigger = i.querySelector('.faq-question');
                if (trigger) trigger.setAttribute('aria-expanded', 'false');
            });
            if (!isActive && answer) {
                item.classList.add('active');
                answer.style.maxHeight = answer.scrollHeight + 'px';
                q.setAttribute('aria-expanded', 'true');
            }
        };
        q.addEventListener('click', toggle);
        q.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                toggle();
            }
        });
    });

    // Smooth scroll offset for fixed elements
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            const href = this.getAttribute('href');
            if (!href || href === '#' || href === '#main-content') return;
            let target;
            try {
                target = document.querySelector(href);
            } catch {
                return;
            }
            if (target) {
                e.preventDefault();
                const stickyHeight = stickyCta && stickyCta.classList.contains('visible') ? stickyCta.offsetHeight : 0;
                window.scrollTo({
                    top: target.offsetTop - stickyHeight,
                    behavior: 'smooth'
                });
            }
        });
    });

    // Contact form via Resend API
    const contactForm = document.getElementById('contactForm');
    if (contactForm) {
        const I18N = {
            en: { success: 'Message sent successfully!', error: 'Failed to send. Please try again.' },
            nl: { success: 'Bericht succesvol verzonden!', error: 'Verzenden mislukt. Probeer het opnieuw.' },
            hu: { success: 'Üzenet sikeresen elküldve!', error: 'A küldés nem sikerült. Kérjük, próbálja újra.' }
        };
        const lang = (document.documentElement.lang || 'en').slice(0, 2).toLowerCase();
        const t = I18N[lang] || I18N.en;
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = this.querySelector('button[type="submit"]');
            const status = document.getElementById('contactStatus');
            const origText = btn.textContent;
            btn.disabled = true;
            btn.textContent = '...';
            status.textContent = '';
            try {
                const res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: this.name.value,
                        email: this.email.value,
                        message: this.message.value
                    })
                });
                if (res.ok) {
                    status.style.color = '#7dcea0';
                    status.textContent = t.success;
                    this.reset();
                } else {
                    status.style.color = '#e74c3c';
                    status.textContent = t.error;
                }
            } catch {
                status.style.color = '#e74c3c';
                status.textContent = t.error;
            }
            btn.disabled = false;
            btn.textContent = origText;
        });
    }
</script>
